# Supabase Configuration (copy to .env.local and fill in real values)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Landing page hero banner (optional). No local image file — upload to Supabase Storage bucket "site-assets", then set URL:
# VITE_BANNER_IMAGE_URL=https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/site-assets/banner-puppies.png

# Public site URL used for canonical URLs, Open Graph URLs, sitemap generation, and robots sitemap output.
VITE_SITE_URL=https://www.yourdomain.com

# "Price Includes" block on puppy/breed pages (src/data/price-includes.ts). Defaults off —
# every line item needs Carlos's confirmation before it's accurate. Set to "true" once confirmed.
# VITE_SHOW_PRICE_INCLUDES=true

# Supabase Service Role Key (for admin scripts only)
# ⚠️  WARNING: This key bypasses Row Level Security (RLS) and has full database access
# ⚠️  NEVER commit the real value to git - keep it secret and use only in server-side scripts
# ⚠️  Get this from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
